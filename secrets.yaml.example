# Copy this file to secrets.yaml and fill in your values.
# secrets.yaml is listed in .gitignore and will never be committed.

wifi_ssid: "Your WiFi SSID"
wifi_password: "your-wifi-password"

# Fallback AP password (shown during Wi-Fi setup)
ap_password: "gecko-setup"

# ESPHome API encryption key (generate with: python3 -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())")
api_encryption_key: "REPLACE_WITH_BASE64_32_BYTE_KEY"

# OTA update password
ota_password: "REPLACE_WITH_SECURE_OTA_PASSWORD"
